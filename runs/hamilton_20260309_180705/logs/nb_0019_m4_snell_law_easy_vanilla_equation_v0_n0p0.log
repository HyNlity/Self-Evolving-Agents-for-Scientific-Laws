{"command":"python3 - << 'EOF'\nfrom math import cos\n\npoints=[(100,0.5,239.10153878893652),\n        (200,1.0,529.0833328166341),\n        (50,0.2,46.524166497185874),\n        (1000,1.2,1807.1768693825784),\n        (500,0.3,724.0530347758668),\n        (500,1.0,1322.708332041585),\n        (500,1.2,903.5884346912892),\n        (500,0.8,1499.1472969901936),\n        (100,0.3,144.81060695517334),\n        (100,0.8,299.8294593980387)]\n\n# 构造矩阵\nX=[]\ny=[]\nfor I0,theta,DI in points:\n    c2=cos(theta)**2\n    c4=cos(theta)**4\n    X.append([I0*1, I0*c2, I0*c4])\n    y.append(DI)\n\n# 用最小二乘手写求解\n# 矩阵乘法和转置\ndef transpose(mat):\n    return list(map(list, zip(*mat)))\n\ndef matmul(A,B):\n    res=[]\n    for i in range(len(A)):\n        row=[]\n        for j in range(len(B[0])):\n            s=0\n            for k in range(len(A[0])):\n                s+=A[i][k]*B[k][j]\n            row.append(s)\n        res.append(row)\n    return res\n\n# 正规方程\nXT=transpose(X)\nXT_X=matmul(XT,X)\nXT_y=[sum(XT[i][j]*y[j] for j in range(len(y))) for i in range(len(XT))]\n\n# 解XT_X * coef = XT_y（3x3）\nimport copy\nA=copy.deepcopy(XT_X)\nb=XT_y\n\n# 高斯消元\ndef gauss(A,b):\n    n=len(b)\n    for i in range(n):\n        # pivot\n        maxrow=max(range(i,n), key=lambda r: abs(A[r][i]))\n        A[i],A[maxrow]=A[maxrow],A[i]\n        b[i],b[maxrow]=b[maxrow],b[i]\n        # normalize\n        pivot=A[i][i]\n        A[i]=[v/pivot for v in A[i]]\n        b[i]=b[i]/pivot\n        # eliminate\n        for r in range(n):\n            if r!=i:\n                factor=A[r][i]\n                A[r]=[A[r][c]-factor*A[i][c] for c in range(n)]\n                b[r]=b[r]-factor*b[i]\n    return b\n\ncoef=gauss(A,b)\nprint(coef)\nEOF"}
{"command":"python3 - << 'EOF'\nfrom math import cos\n\npoints=[(100,0.5,239.10153878893652),\n        (200,1.0,529.0833328166341),\n        (50,0.2,46.524166497185874),\n        (1000,1.2,1807.1768693825784),\n        (500,0.3,724.0530347758668),\n        (500,1.0,1322.708332041585),\n        (500,1.2,903.5884346912892),\n        (500,0.8,1499.1472969901936),\n        (100,0.3,144.81060695517334),\n        (100,0.8,299.8294593980387)]\n\nX=[]\ny=[]\nfor I0,theta,DI in points:\n    c2=cos(theta)**2\n    c4=cos(theta)**4\n    X.append([I0*1, I0*c2, I0*c4])\n    y.append(DI)\n\n# 手写最小二乘求解\ndef transpose(m):\n    return list(map(list, zip(*m)))\n\ndef matmul(a,b):\n    res=[]\n    for i in range(len(a)):\n        row=[]\n        for j in range(len(b[0])):\n            s=0\n            for k in range(len(a[0])):\n                s += a[i][k]*b[k][j]\n            row.append(s)\n        res.append(row)\n    return res\n\nXT = transpose(X)\nXT_X = matmul(XT,X)\nXT_y = [[sum(XT[i][j]*y[j] for j in range(len(y)))] for i in range(len(XT))]\n\n# 高斯消元解三元方程\nimport copy\nA = copy.deepcopy(XT_X)\nb = [row[0] for row in XT_y]\n\nn = len(b)\nfor i in range(n):\n    # pivot行\n    maxr = max(range(i,n), key=lambda r: abs(A[r][i]))\n    A[i],A[maxr] = A[maxr],A[i]\n    b[i],b[maxr] = b[maxr],b[i]\n    # normalize\n    pivot = A[i][i]\n    A[i] = [v/pivot for v in A[i]]\n    b[i] = b[i]/pivot\n    # eliminate\n    for r in range(n):\n        if r != i:\n            factor = A[r][i]\n            A[r] = [A[r][c] - factor*A[i][c] for c in range(n)]\n            b[r] = b[r] - factor*b[i]\n\nprint(b)\nEOF"}
